APP_NAME="Project Manager API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/La_Paz
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=project_manager
DB_USERNAME=postgres
DB_PASSWORD=admin123

# API pura: no se usan sesiones basadas en BD ni cache distribuida por defecto
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Dominios que pueden autenticarse via cookies de Sanctum (SPA)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1
SESSION_DOMAIN=localhost

FRONTEND_URL=http://localhost:3000

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@empresa.com"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=public

# Carga inicial (usada por UserSeeder)
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=Admin123*
